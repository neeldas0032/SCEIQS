      <aliases enabled='yes' />
      <column caption='Nightlight Contribution' datatype='real' name='[Calculation_1187490080251904]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[nightlight_norm] * 0.30' />
      </column>
      <column caption='ATM Contribution' datatype='real' name='[Calculation_1187490080481281]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[atm_norm] * 0.20' />
      </column>
      <column caption='Electricity Contribution' datatype='real' name='[Calculation_1187490080600066]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[electricity_norm] * 0.20' />
      </column>
      <column caption='MSME Contribution' datatype='real' name='[Calculation_1187490080698371]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[msme_norm] * 0.15' />
      </column>
      <column caption='Population Contribution' datatype='real' name='[Calculation_1187490080890884]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[population_norm] * 0.15' />
      </column>
      <column caption='Risk Category' datatype='string' name='[Calculation_1187490117083141]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [shadow_score] &gt;= 0.60 THEN &quot;Very High&quot;&#13;&#10;&#13;&#10;ELSEIF [shadow_score] &gt;= 0.40 THEN &quot;High&quot;&#13;&#10;&#13;&#10;ELSEIF [shadow_score] &gt;= 0.20 THEN &quot;Medium&quot;&#13;&#10;&#13;&#10;ELSE &quot;Low&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Primary Risk Driver' datatype='string' name='[Calculation_1187490117251078]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1187490080481281] &gt;= [Calculation_1187490080600066]&#13;&#10;AND [Calculation_1187490080481281] &gt;= [Calculation_1187490080698371]&#13;&#10;AND [Calculation_1187490080481281] &gt;= [Calculation_1187490080251904]&#13;&#10;AND [Calculation_1187490080481281] &gt;= [Calculation_1187490080890884]&#13;&#10;THEN &quot;ATM Density&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_1187490080600066] &gt;= [Calculation_1187490080481281]&#13;&#10;AND [Calculation_1187490080600066] &gt;= [Calculation_1187490080698371]&#13;&#10;AND [Calculation_1187490080600066] &gt;= [Calculation_1187490080251904]&#13;&#10;AND [Calculation_1187490080600066] &gt;= [Calculation_1187490080890884]&#13;&#10;THEN &quot;Electricity&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_1187490080698371] &gt;= [Calculation_1187490080481281]&#13;&#10;AND [Calculation_1187490080698371] &gt;= [Calculation_1187490080600066]&#13;&#10;AND [Calculation_1187490080698371] &gt;= [Calculation_1187490080251904]&#13;&#10;AND [Calculation_1187490080698371] &gt;= [Calculation_1187490080890884]&#13;&#10;THEN &quot;MSME&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_1187490080251904] &gt;= [Calculation_1187490080481281]&#13;&#10;AND [Calculation_1187490080251904] &gt;= [Calculation_1187490080600066]&#13;&#10;AND [Calculation_1187490080251904] &gt;= [Calculation_1187490080698371]&#13;&#10;AND [Calculation_1187490080251904] &gt;= [Calculation_1187490080890884]&#13;&#10;THEN &quot;Nightlight&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&quot;Population&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='One' datatype='integer' name='[Calculation_1187490122272775]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='District Count' datatype='integer' name='[Calculation_1295788510912514]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([district])' />
      </column>
      <column caption='Top Risk District' datatype='string' name='[Calculation_1295788515758083]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [shadow_rank] = 1&#13;&#10;THEN [district]&#13;&#10;END' />
      </column>
      <column caption='Top Risk State' datatype='string' name='[Calculation_1295788525064196]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [shadow_rank] = 1 THEN [state] END' />
      </column>
      <column caption='High Risk District Count' datatype='integer' name='[Calculation_1295788655276037]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [shadow_score] &gt;= 0.20 THEN 1 END' />
      </column>
